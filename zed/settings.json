// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  // Visual Settings"

  "theme": "Catppuccin Mocha",
  "icon_theme": "Catppuccin Mocha",
  "buffer_font_size": 15,
  "ui_font_size": 16,
  "agent_ui_font_size": 16,
  "agent_buffer_font_size": 14,
  "buffer_font_family": "Monaspace Argon",
  "buffer_font_fallbacks": ["FiraCode Nerd Font"],
  "buffer_font_features": {
    "ss01": true,
    "ss02": true,
    "ss03": true,
    "ss04": true,
    "ss05": true,
    "ss06": true,
    "ss07": true,
    "ss08": true,
    "calt": true,
    "dlig": true,
  },
  "show_completions_on_input": true,
  "wrap_guides": [80, 120],
  "preferred_line_length": 120,
  "show_whitespaces": "trailing",
  "active_pane_modifiers": {
    "inactive_opacity": 0.6,
    "border_size": 0.3,
  },

  "use_system_path_prompts": false,
  "use_system_prompts": false,
  "minimap": { "show": "never" },
  "which_key": {
    "enabled": true,
    "delay_ms": 300,
  },
  "indent_guides": {
    "enabled": true,
    "line_width": 2,
    "active_line_width": 4,
    "coloring": "indent_aware",
    "background_coloring": "disabled",
  },
  "gutter": {
    "folds": false,
  },
  "scrollbar": {
    "show": "auto",
    "axes": {
      "horizontal": false,
    },
  },
  "status_bar": {
    "experimental.show": true,
    "show_active_file": true,
  },
  "colorize_brackets": true,
  "experimental.theme_overrides": {
    // "editor.indent_guide_active": "#FF0000" // When using fixed
    // "editor.indent_guide": "#00FF00" // When using fixed
  },
  "theme_overrides": {
    "Catppuccin Mocha": {
      // "editor.indent_guide_active": "#FF0000",
    },
  },

  // Terminal stuff
  "terminal": {
    "button": true,
    "toolbar": {
      "breadcrumbs": false,
    },
    "cursor_shape": "block",
    "font_family": "Monaspace Argon",
    "font_fallbacks": ["FiraCode Nerd Font"],
    "font_size": 16,
    "line_height": "standard",
    "env": {
      "EDITOR": "zed -w",
      "VISUAL": "zed -w",
      "GIT_EDITOR": "zed --wait",
    },
    "detect_venv": {
      "on": {
        "activate_script": "default",
        "directories": [".venv", "venv"],
      },
    },
  },

  // Panels
  "bottom_dock_layout": "left_aligned",
  "title_bar": {
    "show_branch_status_icon": true,
    "show_project_items": true,
    "show_onboarding_banner": true,
    "show_sign_in": true,
    "show_user_menu": true,
    "show_user_picture": true,
    "show_menus": true,
    "show_branch_name": true,
  },
  "tab_bar": {
    "show": true,
    "show_tab_bar_buttons": false,
    "show_nav_history_buttons": false,
  },
  "tabs": {
    "file_icons": false,
    "git_status": true,
    "show_close_button": "hover",
    "show_diagnostics": "errors",
    "activate_on_close": "history",
  },
  "max_tabs": 8,
  "toolbar": {
    "quick_actions": false,
    "breadcrumbs": false,
    "agent_review": true,
    "code_actions": true,
    "selections_menu": true,
  },
  "project_panel": {
    "folder_icons": true,
    "file_icons": true,
    "indent_size": 10,
    "dock": "right",
    "auto_reveal_entries": false,
    "sticky_scroll": true,
    "hide_root": true,
    "diagnostic_badges": true,
  },
  "git_panel": {
    "dock": "right",
    "tree_view": true,
  },
  "outline_panel": {
    "default_width": 300.0,
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "right",
    "button": true,
  },
  "diagnostics": {
    "inline": {
      "enabled": true,
      "update_debounce_ms": 150,
      "padding": 2,
      "min_column": 80,
      "max_severity": "error",
    },
  },
  "debugger": {
    "button": true,
    "dock": "bottom",
  },
  "search": {
    "button": true,
  },

  // Ensure some extensions are always installed as the config reliest on them
  "auto_install_extensions": {
    "catppuccin": true,
    "catppuccin-icons": true,
    "just": true,
    "rainbow-csv": true,
  },

  // Vim mode setup
  "vim_mode": true,
  "vim": {
    "toggle_relative_line_numbers": false,
    "use_system_clipboard": "on_yank",
    "cursor_shape": {
      "normal": "block",
      "insert": "bar",
      "replace": "underline",
      "visual": "hollow",
    },
  },
  "cursor_blink": false,
  "relative_line_numbers": "enabled",
  "scroll_beyond_last_line": "off",
  "pane_split_direction_horizontal": "down",
  "pane_split_direction_vertical": "right",
  "command_aliases": {
    "close": "workspace::CloseProject",
    "W": "w",
    "Wq": "wq",
    "WQ": "wq",
    "Q": "q",
  },

  // Zed internal workings.
  "on_last_window_closed": "quit_app",
  "cli_default_open_behavior": "existing_window",
  "confirm_quit": true,
  "restore_on_startup": "last_session",
  "use_autoclose": true,
  "format_on_save": "on",
  "auto_indent_on_paste": true,
  "extend_comment_on_newline": false,
  "show_signature_help_after_edits": false,
  "auto_signature_help": false,
  "code_lens": "on",
  "semantic_tokens": "combined",
  "inlay_hints": {
    "enabled": true,
  },
  "feature_flags": {
    "tabular-data-preview": "on",
    "streaming-edit-file-tool": "on",
    "notebooks": "on",
    "project-panel-undo-redo": "on",
  },

  // Collaborative Stuff
  "redact_private_values": false,

  // AI
  "show_edit_predictions": true,
  "edit_predictions": {
    "provider": "zed",
    "mode": "subtle",
  },
  "agent": {
    "limit_content_width": true,
    "max_content_width": 850,
    "default_width": 640,
    "favorite_models": [
      {
        "provider": "OpenCode Go",
        "model": "minimax-m2.7",
        "enable_thinking": false,
      },
      {
        "provider": "OpenCode Go",
        "model": "minimax-m2.5",
        "enable_thinking": false,
      },
      {
        "provider": "anthropic",
        "model": "claude-sonnet-4-6-latest",
        "enable_thinking": true,
        "effort": "high",
      },
    ],
    "dock": "left",
    "sidebar_side": "left",
    "inline_assistant_model": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-6-latest",
      "enable_thinking": false,
    },
    "tool_permissions": {
      "default": "allow",
    },
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "deepseek",
      "model": "deepseek-v4-pro",
    },
    "flexible": true,
    "button": true,
    "default_profile": "write",
    "play_sound_when_agent_done": "always",
  },
  "agent_servers": {
    "opencode": {
      "favorite_config_option_values": {
        "model": ["montel-litellm/gpt-oss:20b", "github-copilot/gpt-5-mini", "opencode/nemotron-3-super-free"],
      },
      "type": "registry",
    },
    "github-copilot-cli": { "type": "registry" },
    "claude-acp": { "type": "registry" },
  },
  "context_servers": {
    "tidewave-mcp": {
      "enabled": true,
      "remote": false,
      "settings": {},
    },
  },
  "language_models": {
    "opencode": {
      "show_zen_models": true,
      "show_go_models": true,
      "show_free_models": true,
    },
    "openai_compatible": {
      "Montel Al": {
        "api_url": "https://litellm.spark-one.montel.care/v1",
        "available_models": [
          {
            "name": "gpt-oss:20b",
            "display_name": "GPT OSS 20b",
            "max_tokens": 32768,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
            },
          },
          {
            "name": "qwen3-coder-next:q8_0",
            "display_name": "Qwen3 Coder Next (Q8)",
            "max_tokens": 32768,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
            },
          },
          {
            "name": "qwen3.6:35b",
            "display_name": "Qwen3.6 35b",
            "max_tokens": 32768,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
            },
          },
          {
            "name": "gemma4:31b",
            "display_name": "Gemma 4 31b",
            "max_tokens": 131072,
            "capabilities": {
              "tools": true,
              "images": true,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
            },
          },
          {
            "name": "gemma4:latest",
            "display_name": "Gemma 4",
            "max_tokens": 131072,
            "capabilities": {
              "tools": true,
              "images": true,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
            },
          },
        ],
      },
    },
  },

  // Git
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": true,
      "show_commit_summary": true,
      "delay_ms": 500,
      "min_column": 80,
      "padding": 2,
    },
  },

  "file_types": {
    "Dockerfile": ["Dockerfile", "Dockerfile.*"],
    "YAML": ["sls"],
    "Markdown": ["qmd", "rmd", "md", "livemd"],
  },
  "file_scan_exclusions": [
    "**/.git",
    "**/.jj",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    // above is default from Zed
    "**/out",
    "**/.next",
    "**/_freeze",
    "**/node_modules",
  ],
  "journal": {
    "hour_format": "hour24",
  },

  "ssh_connections": [],
  // Language Specific Settings
  "languages": {
    "Markdown": {
      "show_edit_predictions": false,
      "soft_wrap": "bounded",
      "preferred_line_length": 120,
    },
    "Elixir": {
      // "language_servers": ["!expert", "dexter", "!elixir-ls", "!next-ls", "!lexical", "..."],
      "language_servers": ["expert", "!dexter", "!elixir-ls", "!next-ls", "!lexical", "..."],
      // "language_servers": ["expert"],
    },
    "HEEx": {
      // "language_servers": ["!expert", "!elixir-ls", "!next-ls", "!lexical", "..."],
      // "language_servers": ["tailwindcss-language-server", "expert", "emmet-language-server"],
      // "language_servers": ["expert"],
    },
    "Python": {
      "code_actions_on_format": {
        "source.organizeImports.ruff": true,
      },
      "language_servers": ["ty", "ruff", "!basedpyright", "!pyrefly", "!pyright", "!pylsp"],
    },
    "JSON": {
      "wrap_guides": [],
      "use_autoclose": true,
    },
    "JSONC": {
      "wrap_guides": [],
      "use_autoclose": true,
    },
    "R": {
      // "language_servers": ["air"],
      "format_on_save": "on",
      "tab_size": 2,
    },
    "Ruby": {
      "language_servers": ["ruby-lsp", "!solargraph", "!rubocop", "..."],
    },
    "Rust": {},
    "Zig": {},
    "Lua": {},
    "Typst": {
      "soft_wrap": "bounded",
      "preferred_line_length": 80,
    },
    "TypeScript": {
      "tab_size": 4,
      "inlay_hints": {
        "enabled": true,
        "show_parameter_hints": false,
        "show_type_hints": true,
        "show_other_hints": true,
      },
    },
  },

  // LSP Settings
  "global_lsp_settings": {
    "semantic_token_rules": [
      { "token_type": "conflictMarker", "foreground_color": "#569cd6" },
      { "token_type": "conflictSnapshot", "foreground_color": "#9cdcfe" },
      { "token_type": "conflictAddition", "foreground_color": "#6a9955" },
      { "token_type": "conflictDeletion", "foreground_color": "#f44747" },
    ],
  },
  "lsp": {
    "expert": {
      "binary": {
        "arguments": ["--stdio"],
      },
    },
    "tinymist": {
      "settings": {
        // "exportPdf": "onSave",
        "outputPath": "$root/target/$dir/$name",
      },
      "initialization_options": {
        "preview": {
          "background": {
            "enabled": true,
          },
        },
      },
    },
    "rubocop": {
      "initialization_options": {},
    },
    "ruby-lsp": {
      "initialization_options": {
        "enabledFeatures": {
          // "diagnostics": false,
          // "linters": ["standard"],
          // "formatter": "none"
        },
      },
    },
    "harper-ls": {
      "settings": {
        "harper-ls": {
          "completionEnabled": true,
          "userDictPath": "~/dict.txt",
          "fileDictPath": "~/.harper/",
          "diagnosticSeverity": "information",
          "codeActions": {
            "forceStable": false, // Force code actions to appear in "stable" positions
          },
          "linters": {
            "spell_check": true,
            "spelled_numbers": true,
            "an_a": true,
            "sentence_capitalization": true,
            "unclosed_quotes": true,
            "wrong_quotes": true,
            "long_sentences": true,
            "repeated_words": true,
            "spaces": true,
            "matcher": true,
            "correct_number_suffix": true,
            "number_suffix_capitalization": true,
            "multiple_sequential_pronouns": true,
            "linking_verbs": true,
            "avoid_curses": true,
            "terminating_conjunctions": true,
          },
        },
      },
    },
    // "ruff": {
    //   "initialization_options": {
    //     "settings": {
    //       // Ruff server settings goes here
    //       "lineLength": 80,
    //       "lint": {
    //         "extendSelect": ["E", "F", "I"]
    //       }
    //     }
    //   }
    // }
  },

  "profiles": {
    "Classic Layout": {
      "base": "user",
      "settings": {
        "agent": { "dock": "right" },
        "project_panel": { "dock": "left" },
        "outline_panel": { "dock": "left" },
        "git_panel": { "dock": "left" },
      },
    },
  },

  // The End...
}
